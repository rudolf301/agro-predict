# Copy to `.env` and fill in. Values are read automatically at startup.

# OpenAI API key for GPT-4o enrichment of predictions.
# If set, /predict automatically enriches with GPT unless the client passes X-OpenAI-Key (override).
# Leave empty to disable GPT and use rule-based explanations only.
OPENAI_API_KEY=

# Default model to use when OPENAI_API_KEY is set.
# Common values: gpt-4o, gpt-4o-mini, gpt-4-turbo.
OPENAI_MODEL=gpt-4o-mini
